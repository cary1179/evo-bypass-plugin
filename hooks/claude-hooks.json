{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/session-start-service.js\" --runtime claude",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/collect-event.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/collect-event.js\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/collect-event.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/enqueue-review-job.js\" --runtime claude",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
