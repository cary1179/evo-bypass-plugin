{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/collect-event.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/collect-event.js\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/collect-event.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$EVO_BYPASS_HOME/scripts/review-session.js\"",
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
